# BizChat Redes — variables de entorno
# --------------------------------------------------------------------
# Modelo BYOK: basta con UNA key para que la IA real funcione.
# La función elige el proveedor según qué key esté configurada.
# En Vercel se agregan en: Project → Settings → Environment Variables
# (NO subas este archivo con valores reales — .env* está en .gitignore).

# Claude (recomendado: barato y rápido con Haiku)
ANTHROPIC_API_KEY=

# OpenAI (opcional)
OPENAI_API_KEY=

# Gemini (opcional)
GOOGLE_GENERATIVE_AI_API_KEY=

# Proveedor por defecto si el visitante no fuerza uno: anthropic | openai | google
DEFAULT_PROVIDER=anthropic
